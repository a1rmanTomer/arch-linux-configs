# BakkesMod Update Command
update_bm() {
    echo "Extracting DLL from desktop ZIP..."
    7z e "/home/tomer/Desktop/no-touch-things-to-keep/BakkesModSetup.zip" bakkesmod.dll -r -o"/home/tomer/Games/Heroic/Prefixes/default/Rocket League/drive_c/Program Files/BakkesMod/" -y

    echo "Disabling Safe Mode..."
    mkdir -p "/home/tomer/Games/Heroic/Prefixes/default/Rocket League/drive_c/Program Files/BakkesMod/cfg"
    echo 'EnableSafeMode "0"' > "/home/tomer/Games/Heroic/Prefixes/default/Rocket League/drive_c/Program Files/BakkesMod/cfg/config.cfg"

    echo "Update complete! You can now launch the game."
}

