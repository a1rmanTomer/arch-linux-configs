# Plugin Installer Function
bm_plugin_install() {
    local PLUGIN_ZIP="$1"
    local BM_REAL_PATH="/home/tomer/Games/Heroic/Prefixes/default/Rocket League/drive_c/users/steamuser/AppData/Roaming/bakkesmod/bakkesmod/"

    if [ -f "$PLUGIN_ZIP" ]; then
        echo "Target directory: $BM_REAL_PATH"
        echo "Installing plugin..."
        
        # Extract with full paths to ensure /data/ and /plugins/ land in the right spot
        7z x "$PLUGIN_ZIP" -o"$BM_REAL_PATH" -y
        
        echo "Installation finished."
        echo "In Rocket League, open F6 console and type: plugin reload LFM"
    else
        echo "Error: File not found. Please provide the full path to the ZIP file."
    fi
}

