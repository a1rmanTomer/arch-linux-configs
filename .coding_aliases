export TOMER_LIB_PATH="$HOME/tomer_lib"

# 1. For #include <tomer.h>
export C_INCLUDE_PATH="$TOMER_LIB_PATH:$C_INCLUDE_PATH"

# 2. For linking during compilation (gcc main.c -ltomer)
export LIBRARY_PATH="$TOMER_LIB_PATH:$LIBRARY_PATH"

# 3. For runtime execution (loading libtomer.so into memory)
export LD_LIBRARY_PATH="$TOMER_LIB_PATH:$LD_LIBRARY_PATH"

